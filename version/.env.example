# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/moviematch?schema=public"
# Locally same as DATABASE_URL. On Vercel Postgres this is the direct (non-pooled) URL.
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/moviematch?schema=public"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# Some Auth.js v5 setups still read NEXTAUTH_URL in dev
NEXTAUTH_URL="http://localhost:3000"

# TMDB API v3 key — get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY="your-tmdb-v3-api-key"

# Optional: path to your Letterboxd ratings.csv export, used by
# `npm run import:letterboxd` to seed your taste profile. Defaults to the
# path baked into src/lib/letterboxd.ts if unset.
# LETTERBOXD_CSV_PATH="/absolute/path/to/letterboxd-export/ratings.csv"
